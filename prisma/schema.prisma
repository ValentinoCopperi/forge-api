generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  GERENTE
  EMPLEADO
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
   avatarUrl    String?    
  tasks        Task[]
  userRoles    UserRole[]
}

model Task {
  id     Int    @id @default(autoincrement())
  title  String
  description String?
  status   TaskStatus @default(PENDING)
  userId Int
  user   User   @relation(fields: [userId], references: [id])
}

model UserRole {
  userId Int
  role Role
  user   User @relation(fields: [userId], references: [id])

  @@id([userId, role])
}
