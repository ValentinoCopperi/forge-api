generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DIRECTOR
  GERENTE
  EMPLEADO
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
   avatarUrl    String?
  tasks        Task[]
  userRoles    UserRole[]
  sessions     Session[]
}

model Task {
  id     Int    @id @default(autoincrement())
  title  String
  description String?
  status   TaskStatus @default(PENDING)
  userId Int
  user   User   @relation(fields: [userId], references: [id])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model UserRole {
  userId Int
  role Role
  user   User @relation(fields: [userId], references: [id])

  @@id([userId, role])
}
